---
import "../styles/global.css";
---

<html lang="fr" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>PowerAlert - Dashboard</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			/* Reset and base styles reinforced */
			html,
			body {
				margin: 0;
				padding: 0;
				overflow: hidden;
				font-family: "Inter", sans-serif;
				background-color: #171920;
			}

			.dashboard-window {
				width: 440px;
				height: 100vh;
				background-color: #171920;
				display: flex;
				flex-direction: column;
				border-radius: 10px;
				box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
				border: 1px solid rgba(255, 255, 255, 0.03);
				z-index: 100;
				position: relative;
				user-select: none;
				box-sizing: border-box;
			}

			.window-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 32px 32px 0 32px;
				flex-shrink: 0;
			}

			.window-title {
				font-size: 1rem;
				font-weight: 700;
				color: #f0f0f8;
				margin: 0;
			}

			.minimize-btn {
				background: transparent;
				border: none;
				color: #aaaab2;
				cursor: pointer;
				opacity: 0.6;
				transition: opacity 0.2s;
				padding: 0;
			}

			.battery-section {
				display: flex;
				justify-content: center;
				padding: 24px 32px;
				flex-shrink: 0;
			}

			.battery-ring {
				position: relative;
				width: 200px;
				height: 200px;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.ring-core {
				display: flex;
				flex-direction: column;
				align-items: center;
				z-index: 10;
			}

			.battery-value {
				font-size: 3.5rem;
				font-weight: 800;
				color: #f0f0f8;
				line-height: 1;
			}

			.charging-status {
				display: flex;
				align-items: center;
				gap: 4px;
				margin-top: 12px;
				color: #5dfd8c;
				background: rgba(93, 253, 140, 0.1);
				padding: 4px 10px;
				border-radius: 20px;
			}

			.status-text {
				font-size: 0.65rem;
				font-weight: 800;
				letter-spacing: 0.05em;
			}

			.progress-svg {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				transform: rotate(-90deg);
			}

			.svg-track {
				fill: transparent;
				stroke: #23262e;
				stroke-width: 8;
			}

			.svg-progress {
				fill: transparent;
				stroke: #5dfd8c;
				stroke-width: 8;
				stroke-linecap: round;
				filter: drop-shadow(0 0 8px rgba(93, 253, 140, 0.4));
			}

			.settings-list {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}

			.setting-item {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			.setting-info {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.setting-label {
				font-size: 0.65rem;
				font-weight: 700;
				color: #aaaab2;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}

			.setting-value {
				font-size: 0.75rem;
				font-weight: 700;
				color: #5dfd8c;
			}

			.slider-container {
				cursor: pointer;
				padding: 8px 0;
			}

			.slider-track {
				height: 4px;
				background: #23262e;
				border-radius: 2px;
				position: relative;
			}

			.slider-fill {
				height: 100%;
				background: #5dfd8c;
				border-radius: 2px;
				pointer-events: none;
			}

			.slider-thumb {
				position: absolute;
				top: 50%;
				transform: translate(-50%, -50%);
				width: 12px;
				height: 12px;
				background: #5dfd8c;
				border-radius: 4px;
				box-shadow: 0 0 10px rgba(93, 253, 140, 0.5);
				pointer-events: none;
			}

			.setting-toggle-item {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 8px;
			}

			.toggle-switch {
				width: 44px;
				height: 22px;
				background: #23262e;
				border-radius: 11px;
				position: relative;
				cursor: pointer;
				transition: background 0.3s;
			}

			.toggle-switch.active {
				background: #5dfd8c;
			}

			.toggle-thumb {
				width: 18px;
				height: 18px;
				background: #000;
				border-radius: 50%;
				position: absolute;
				top: 2px;
				left: 2px;
				transition: transform 0.3s;
				pointer-events: none;
			}

			.toggle-switch.active .toggle-thumb {
				transform: translateX(22px);
			}

			.window-footer p {
				font-size: 0.6rem;
				color: #aaaab2;
				text-align: center;
				line-height: 1.5;
				margin: 0;
			}

			/* Section Santé de la batterie */
			.health-section {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			.health-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 12px;
			}

			.health-card {
				background: rgba(255, 255, 255, 0.02);
				border: 1px solid rgba(255, 255, 255, 0.05);
				padding: 12px;
				border-radius: 12px;
				display: flex;
				flex-direction: column;
				gap: 4px;
				transition: border-color 0.2s;
			}

			.health-card:hover {
				border-color: rgba(93, 253, 140, 0.2);
			}

			.health-label {
				font-size: 0.55rem;
				font-weight: 700;
				color: #aaaab2;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.health-value {
				font-size: 1rem;
				font-weight: 800;
				color: #f0f0f8;
			}

			.wear-info {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
			}

			.wear-percentage {
				font-size: 0.7rem;
				font-weight: 700;
				color: #5dfd8c;
			}

			.wear-gauge-container {
				height: 4px;
				background: #23262e;
				border-radius: 2px;
				margin-top: 6px;
				overflow: hidden;
			}

			.wear-gauge-fill {
				height: 100%;
				background: #5dfd8c;
				border-radius: 2px;
				width: 0%;
				transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
			}

			/* Tooltips */
			.help-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 14px;
				height: 14px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.1);
				color: #aaaab2;
				font-size: 10px;
				font-weight: 800;
				cursor: help;
				margin-left: 6px;
				transition: all 0.2s;
			}

			.help-icon:hover {
				background: rgba(93, 253, 140, 0.2);
				color: #5dfd8c;
			}

			.has-tooltip {
				position: relative;
				display: flex;
				align-items: center;
			}

			.tooltip {
				position: absolute;
				top: calc(100% + 10px);
				left: 50%;
				transform: translateX(-50%) translateY(-5px);
				background: #23262e;
				color: #f0f0f8;
				padding: 10px 14px;
				border-radius: 8px;
				font-size: 0.65rem;
				font-weight: 500;
				line-height: 1.4;
				width: 180px;
				box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.05);
				pointer-events: none;
				opacity: 0;
				transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
				z-index: 1000;
				text-align: center;
			}

			.tooltip::after {
				content: "";
				position: absolute;
				bottom: 100%;
				left: 50%;
				transform: translateX(-50%);
				border-width: 5px;
				border-style: solid;
				border-color: transparent transparent #23262e transparent;
			}

			.has-tooltip:hover .tooltip {
				opacity: 1;
				transform: translateX(-50%) translateY(0);
			}

			/* Contenu défilable */
			.scrollable-content {
				flex: 1;
				overflow-y: auto;
				padding: 8px 32px 32px 32px;
				display: flex;
				flex-direction: column;
				gap: 32px;
				/* Masquer la scrollbar par défaut sur Firefox */
				scrollbar-width: thin;
				scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
			}

			/* Style de la scrollbar personnalisée (WebKit) */
			.scrollable-content::-webkit-scrollbar {
				width: 6px;
			}

			.scrollable-content::-webkit-scrollbar-track {
				background: transparent;
			}

			.scrollable-content::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.1);
				border-radius: 10px;
				border: 2px solid transparent;
				background-clip: padding-box;
			}

			.scrollable-content::-webkit-scrollbar-thumb:hover {
				background: rgba(93, 253, 140, 0.3);
				border: 2px solid transparent;
				background-clip: padding-box;
			}
		</style>
	</head>
	<body>
		<main class="dashboard-window">
			<header class="window-header">
				<h1 class="window-title">PowerAlert</h1>
				<button
					class="minimize-btn"
					aria-label="Réduire"
					id="minimize-btn"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><line x1="5" y1="12" x2="19" y2="12"></line></svg
					>
				</button>
			</header>

			<section class="battery-section">
				<div class="battery-ring" id="battery-ring">
					<div class="ring-core">
						<span class="battery-value" id="battery-value">--%</span
						>
						<div
							class="charging-status"
							id="charging-status"
							style="opacity: 0;"
						>
							<svg
								id="charging-icon"
								xmlns="http://www.w3.org/2000/svg"
								width="14"
								height="14"
								viewBox="0 0 24 24"
								fill="#5dfd8c"
								stroke="#5dfd8c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><polygon
									points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
								></polygon></svg
							>
							<span class="status-text">--</span>
						</div>
					</div>
					<svg class="progress-svg" viewBox="0 0 200 200">
						<circle class="svg-track" cx="100" cy="100" r="90"
						></circle>
						<circle
							class="svg-progress"
							id="battery-progress"
							cx="100"
							cy="100"
							r="90"
							stroke-dasharray="565.48"
							stroke-dashoffset="84.82"></circle>
					</svg>
				</div>
			</section>

			<div class="scrollable-content">
				<section class="health-section">
					<div class="health-grid">
						<!-- Cycles de charge -->
						<div
							class="health-card"
							id="card-cycles"
							style="display: none;"
						>
							<div style="display: flex; align-items: center;">
								<span class="health-label"
									>Cycles de charge</span
								>
								<div
									class="has-tooltip"
									style="margin-left: 6px;"
								>
									<span
										class="help-icon"
										style="margin-left: 0;">?</span
									>
									<div class="tooltip">
										Un cycle complet correspond à
										l'utilisation cumulée de 100% de la
										capacité totale.
									</div>
								</div>
							</div>
							<span class="health-value" id="cycle-count">--</span
							>
						</div>

						<!-- Usure réelle -->
						<div
							class="health-card"
							id="card-wear"
							style="display: none;"
						>
							<div class="wear-info">
								<div
									style="display: flex; align-items: center;"
								>
									<span class="health-label"
										>Usure réelle</span
									>
									<div
										class="has-tooltip"
										style="margin-left: 6px;"
									>
										<span
											class="help-icon"
											style="margin-left: 0;">?</span
										>
										<div class="tooltip">
											Perte de capacité par rapport à
											l'état d'usine. Plus ce score est
											bas, mieux c'est.
										</div>
									</div>
								</div>
								<span class="wear-percentage" id="wear-level"
									>--%</span
								>
							</div>
							<div class="wear-gauge-container">
								<div class="wear-gauge-fill" id="wear-gauge">
								</div>
							</div>
						</div>

						<!-- Capacité Maximale -->
						<div
							class="health-card"
							id="card-capacity"
							style="display: none;"
						>
							<div class="wear-info">
								<div
									style="display: flex; align-items: center;"
								>
									<span class="health-label" id="label-cap"
										>Capacité Maximale</span
									>
									<div
										class="has-tooltip"
										style="margin-left: 6px;"
									>
										<span
											class="help-icon"
											style="margin-left: 0; margin-right: 10px;"
											>?</span
										>
										<div class="tooltip">
											Rapport entre la charge maximale
											actuelle et la capacité d'usine. Une
											baisse indique que la batterie
											stocke moins d'énergie.
										</div>
									</div>
								</div>
								<span class="wear-percentage" id="cap-ratio"
									>-- / -- Wh</span
								>
							</div>
							<div class="wear-gauge-container">
								<div class="wear-gauge-fill" id="cap-gauge">
								</div>
							</div>
						</div>

						<!-- Température -->
						<div
							class="health-card"
							id="card-temp"
							style="display: none;"
						>
							<div style="display: flex; align-items: center;">
								<span class="health-label">Température</span>
								<div
									class="has-tooltip"
									style="margin-left: 6px;"
								>
									<span
										class="help-icon"
										style="margin-left: 0;">?</span
									>
									<div class="tooltip">
										Température interne. Maintenir entre
										20°C et 35°C pour une longévité
										optimale. Évitez les pics > 45°C.
									</div>
								</div>
							</div>
							<span class="health-value" id="battery-temp"
								>--°C</span
							>
						</div>

						<!-- Consommation -->
						<div
							class="health-card"
							id="card-power"
							style="display: none;"
						>
							<div style="display: flex; align-items: center;">
								<span class="health-label">Consommation</span>
								<div
									class="has-tooltip"
									style="margin-left: 6px;"
								>
									<span
										class="help-icon"
										style="margin-left: 0;">?</span
									>
									<div class="tooltip">
										Énergie utilisée par le système en temps
										réel (Watts). Un chiffre élevé indique
										une utilisation intensive.
									</div>
								</div>
							</div>
							<span class="health-value" id="power-usage"
								>-- W</span
							>
						</div>
					</div>
				</section>

				<section class="settings-list">
					<!-- Max Charge Alerte -->
					<div class="setting-item">
						<div class="setting-info">
							<label class="setting-label"
								>ALERTE DE CHARGE MAXIMALE (%)</label
							>
							<span class="setting-value" id="max-charge-val"
								>100</span
							>
						</div>
						<div class="slider-container" id="max-charge-slider">
							<div class="slider-track">
								<div
									class="slider-fill"
									id="max-charge-fill"
									style="width: 100%;"
								>
								</div>
								<div
									class="slider-thumb"
									id="max-charge-thumb"
									style="left: 100%;"
								>
								</div>
							</div>
						</div>
					</div>

					<!-- Low Battery Alerte -->
					<div class="setting-item">
						<div class="setting-info">
							<label class="setting-label"
								>ALERTE DE BATTERIE FAIBLE (%)</label
							>
							<span class="setting-value" id="low-battery-val"
								>50</span
							>
						</div>
						<div class="slider-container" id="low-battery-slider">
							<div class="slider-track">
								<div
									class="slider-fill"
									id="low-battery-fill"
									style="width: 50%;"
								>
								</div>
								<div
									class="slider-thumb"
									id="low-battery-thumb"
									style="left: 50%;"
								>
								</div>
							</div>
						</div>
					</div>

					<!-- Desktop Sync Toggle -->
					<div class="setting-toggle-item">
						<label
							class="setting-label"
							style="max-width: 200px; text-transform:none;"
							>Lancer PowerAlert au démarrage de Windows</label
						>
						<div class="toggle-switch active" id="startup-toggle">
							<div class="toggle-thumb"></div>
						</div>
					</div>

					<!-- Start Minimized Toggle -->
					<div class="setting-toggle-item">
						<label
							class="setting-label"
							style="max-width: 200px; text-transform:none;"
							>Démarrer l'application en mode réduit</label
						>
						<div class="toggle-switch" id="minimized-toggle">
							<div class="toggle-thumb"></div>
						</div>
					</div>
				</section>

				<footer class="window-footer" style="display: block;">
					<p>
						Paramètres sauvegardés automatiquement. La fermeture
						réduit l'application en arrière-plan.
					</p>
				</footer>
			</div>
		</main>

		<script>
			import { invoke } from "@tauri-apps/api/core";
			import { listen } from "@tauri-apps/api/event";
			import { getCurrentWindow } from "@tauri-apps/api/window";

			// Activation du drag natif via l'API Tauri (fiable avec decorations: false)
			const appWindow = getCurrentWindow();
			// Zone de déplacement (Dragging) customisée
			// On écoute sur `document.body` pour couvrir tout le haut de la fenêtre (y compris le padding)
			document.body.addEventListener("mousedown", (e: MouseEvent) => {
				// Condition : Clic se trouvant de 0 jusqu'à ~70px (zone du titre + headers + marges)
				if (e.clientY <= 70) {
					// Ignorer le clic sur des boutons ou sliders pour ne pas bloquer les intéractions UI natives
					if (
						(e.target as HTMLElement).closest("button") ||
						(e.target as HTMLElement).closest(".slider-container")
					) {
						return;
					}
					appWindow.startDragging();
				}
			});

			// Gestion du bouton minimiser
			const minimizeBtn = document.querySelector(".minimize-btn");
			if (minimizeBtn) {
				minimizeBtn.addEventListener("click", async (e) => {
					e.preventDefault();
					e.stopPropagation();
					try {
						await appWindow.hide();
					} catch (err) {
						console.error(
							"[DEBUG] Erreur bloquant le masquage (permissions Tauri V2 ?) : ",
							err,
						);
					}
				});
			}
			import { enable, disable } from "@tauri-apps/plugin-autostart";

			interface BatteryInfo {
				percentage: number;
				is_plugged_in: boolean;
				state: string;
				temperature: number | null;
				power_usage: number | null;
			}

			interface AppConfig {
				low_threshold: number;
				high_threshold: number;
				run_at_startup: boolean;
				start_minimized: boolean;
			}

			interface BatteryHealth {
				cycle_count: number | null;
				design_capacity: number | null;
				full_charge_capacity: number | null;
				wear_level: number | null;
			}

			// Mise à jour de l'affichage de la batterie
			function updateBatteryUI(info: BatteryInfo) {
				const valueLabel = document.getElementById("battery-value");
				const progress = document.getElementById("battery-progress");
				const statusText = document.querySelector(".status-text");

				// Température
				const tempLabel = document.getElementById("battery-temp");
				const tempCard = document.getElementById("card-temp");
				if (tempCard && tempLabel) {
					if (info.temperature != null) {
						tempLabel.textContent = `${Math.round(info.temperature)}°C`;
						tempCard.style.display = "flex";
					} else {
						tempCard.style.display = "none";
					}
				}

				// Puissance
				const powerLabel = document.getElementById("power-usage");
				const powerCard = document.getElementById("card-power");
				if (powerCard && powerLabel) {
					if (info.power_usage != null && info.power_usage !== 0) {
						powerLabel.textContent = `${Math.abs(info.power_usage).toFixed(1)} W`;
						powerCard.style.display = "flex";
					} else {
						powerCard.style.display = "none";
					}
				}

				if (valueLabel)
					valueLabel.textContent = `${Math.round(info.percentage)}%`;

				if (progress) {
					const radius = 90;
					const circumference = 2 * Math.PI * radius;
					const offset =
						circumference - (info.percentage / 100) * circumference;
					progress.style.strokeDashoffset = offset.toString();

					// Changement de couleur selon le niveau
					const svgProgress = progress as unknown as SVGCircleElement;
					if (info.percentage <= 20) {
						svgProgress.style.stroke = "#ff4d4d";
					} else if (info.percentage <= 50) {
						svgProgress.style.stroke = "#ff9f43";
					} else {
						svgProgress.style.stroke = "#5dfd8c";
					}
				}

				if (statusText)
					statusText.textContent = info.is_plugged_in
						? "EN CHARGE"
						: "SUR BATTERIE";
				const chargingStatus =
					document.getElementById("charging-status");
				if (chargingStatus)
					(chargingStatus as any).style.opacity = info.is_plugged_in
						? "1"
						: "0";
			}

			// Mise à jour de la santé de la batterie
			function updateHealthUI(health: BatteryHealth) {
				const cycleLabel = document.getElementById("cycle-count");
				const cycleCard = document.getElementById("card-cycles");
				const wearLabel = document.getElementById("wear-level");
				const wearCard = document.getElementById("card-wear");
				const wearGauge = document.getElementById(
					"wear-gauge",
				) as HTMLElement;

				// Capacité
				const capLabel = document.getElementById("cap-ratio");
				const capCard = document.getElementById("card-capacity");
				const capGauge = document.getElementById(
					"cap-gauge",
				) as HTMLElement;

				if (capCard && capLabel) {
					if (
						health.full_charge_capacity != null &&
						health.design_capacity != null
					) {
						const currentWh = health.full_charge_capacity / 1000;
						const designWh = health.design_capacity / 1000;

						capLabel.textContent = `${currentWh.toFixed(1)} / ${designWh.toFixed(0)} Wh`;
						capCard.style.display = "flex";

						if (capGauge) {
							const healthPercent =
								(health.full_charge_capacity /
									health.design_capacity) *
								100;
							capGauge.style.width = `${healthPercent}%`;

							// Couleur de la jauge
							if (healthPercent < 70)
								capGauge.style.background = "#ff4d4d";
							else if (healthPercent < 85)
								capGauge.style.background = "#ff9f43";
							else capGauge.style.background = "#5dfd8c";
						}
					} else {
						capCard.style.display = "none";
					}
				}

				if (cycleCard && cycleLabel) {
					if (health.cycle_count != null) {
						cycleLabel.textContent = health.cycle_count.toString();
						cycleCard.style.display = "flex";
					} else {
						cycleCard.style.display = "none";
					}
				}

				if (wearCard && wearLabel && health.wear_level != null) {
					wearCard.style.display = "flex";
					const wear = Math.max(
						0,
						Math.round(health.wear_level * 10) / 10,
					);
					wearLabel.textContent = `${wear}%`;

					if (wearGauge) {
						const healthRemaining = 100 - wear;
						wearGauge.style.width = `${healthRemaining}%`;

						if (healthRemaining < 70) {
							wearGauge.style.background = "#ff4d4d";
							wearLabel.style.color = "#ff4d4d";
						} else if (healthRemaining < 85) {
							wearGauge.style.background = "#ff9f43";
							wearLabel.style.color = "#ff9f43";
						} else {
							wearGauge.style.background = "#5dfd8c";
							wearLabel.style.color = "#5dfd8c";
						}
					}
				} else if (wearCard) {
					wearCard.style.display = "none";
				}
			}

			// Retarde l'exécution d'une fonction jusqu'à la fin d'une période d'inactivité
			function debounce<T extends unknown[]>(
				fn: (...args: T) => void,
				delayMs: number,
			) {
				let timer: ReturnType<typeof setTimeout>;
				return (...args: T) => {
					clearTimeout(timer);
					timer = setTimeout(() => fn(...args), delayMs);
				};
			}

			// Gestion des Sliders de pourcentage
			function initSlider(
				sliderId: string,
				valueId: string,
				fillId: string,
				thumbId: string,
				onChange?: (val: number) => void,
			) {
				const slider = document.getElementById(sliderId);
				const valueLabel = document.getElementById(valueId);
				const fill = document.getElementById(fillId);
				const thumb = document.getElementById(thumbId);

				if (!slider || !valueLabel || !fill || !thumb) return;

				let isDragging = false;

				function setUIValue(percentage: number) {
					if (!valueLabel || !fill || !thumb) return;
					valueLabel.textContent = percentage.toString();
					fill.style.width = percentage + "%";
					thumb.style.left = percentage + "%";
				}

				function updateValue(clientX: number, finalize = false) {
					if (!slider) return;
					const rect = slider.getBoundingClientRect();
					let percentage = ((clientX - rect.left) / rect.width) * 100;
					percentage = Math.min(
						100,
						Math.max(0, Math.round(percentage)),
					);

					setUIValue(percentage);
					if (finalize && onChange) {
						onChange(percentage);
					}
				}

				slider.addEventListener("mousedown", (e: MouseEvent) => {
					isDragging = true;
					updateValue(e.clientX);
				});

				window.addEventListener("mousemove", (e: MouseEvent) => {
					if (isDragging) {
						updateValue(e.clientX);
					}
				});

				window.addEventListener("mouseup", (e: MouseEvent) => {
					if (isDragging) {
						isDragging = false;
						updateValue(e.clientX, true);
					}
				});

				// Support tactile
				slider.addEventListener("touchstart", (e: TouchEvent) => {
					isDragging = true;
					if (e.touches[0]) updateValue(e.touches[0].clientX);
				});

				window.addEventListener("touchmove", (e: TouchEvent) => {
					if (isDragging && e.touches[0]) {
						updateValue(e.touches[0].clientX);
					}
				});

				window.addEventListener("touchend", (e: TouchEvent) => {
					if (isDragging) {
						isDragging = false;
						// Pour le tactile on ne récupère pas facilement la position finale du doigt
						// On se contente de la dernière valeur
						const finalVal = parseInt(
							valueLabel.textContent || "0",
						);
						if (onChange) onChange(finalVal);
					}
				});

				return { setUIValue };
			}

			// Configuration locale
			let currentConfig: AppConfig = {
				low_threshold: 50,
				high_threshold: 100,
				run_at_startup: false,
				start_minimized: false,
			};

			async function saveCurrentConfig() {
				try {
					await invoke("save_config", { config: currentConfig });

					// Activation réelle au niveau du système (plugin-autostart)
					if (currentConfig.run_at_startup) {
						await enable();
					} else {
						await disable();
					}
				} catch (err) {
					console.error("Failed to save config:", err);
				}
			}

			// Initialisation des sliders
			const debouncedSave = debounce(() => saveCurrentConfig(), 300);

			const maxSlider = initSlider(
				"max-charge-slider",
				"max-charge-val",
				"max-charge-fill",
				"max-charge-thumb",
				(val) => {
					currentConfig.high_threshold = val;
					debouncedSave();
				},
			);

			const lowSlider = initSlider(
				"low-battery-slider",
				"low-battery-val",
				"low-battery-fill",
				"low-battery-thumb",
				(val) => {
					currentConfig.low_threshold = val;
					debouncedSave();
				},
			);

			// Gestion du Toggle Démarrage
			const startupToggle = document.getElementById("startup-toggle");
			if (startupToggle) {
				startupToggle.addEventListener("click", () => {
					startupToggle.classList.toggle("active");
					currentConfig.run_at_startup =
						startupToggle.classList.contains("active");
					saveCurrentConfig();
				});
			}

			// Gestion du Toggle Minimisé
			const minimizedToggle = document.getElementById("minimized-toggle");
			if (minimizedToggle) {
				minimizedToggle.addEventListener("click", () => {
					minimizedToggle.classList.toggle("active");
					currentConfig.start_minimized =
						minimizedToggle.classList.contains("active");
					saveCurrentConfig();
				});
			}

			// Chargement initial et écoute des événements
			async function init() {
				try {
					// 1. Charger la config
					const config = (await invoke("get_config")) as AppConfig;
					currentConfig = config;

					if (maxSlider) maxSlider.setUIValue(config.high_threshold);
					if (lowSlider) lowSlider.setUIValue(config.low_threshold);
					if (startupToggle) {
						if (config.run_at_startup)
							startupToggle.classList.add("active");
						else startupToggle.classList.remove("active");
					}
					if (minimizedToggle) {
						if (config.start_minimized)
							minimizedToggle.classList.add("active");
						else minimizedToggle.classList.remove("active");
					}

					// 2. Charger l'état actuel de la batterie
					const initialStatus = (await invoke(
						"get_battery_status",
					)) as BatteryInfo;
					updateBatteryUI(initialStatus);

					// 3. Charger la santé de la batterie
					const health = (await invoke(
						"get_battery_health",
					)) as BatteryHealth;
					updateHealthUI(health);

					// 4. Écouter les mises à jour
					await listen("battery-status", (event) => {
						updateBatteryUI(event.payload as BatteryInfo);
					});
				} catch (err) {
					console.error("IPC Error:", err);
				}
			}

			// Démarrage
			init();

			// Effet visuel bonus
			const batteryRing = document.getElementById("battery-ring");
			if (batteryRing) {
				batteryRing.style.transition = "transform 0.3s ease";
				batteryRing.addEventListener("mouseenter", () => {
					batteryRing.style.transform = "scale(1.02)";
				});
				batteryRing.addEventListener("mouseleave", () => {
					batteryRing.style.transform = "scale(1)";
				});
			}
		</script>
	</body>
</html>
