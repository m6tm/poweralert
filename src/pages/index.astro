---
import "../styles/global.css";
---

<html lang="fr" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>PowerAlert - Dashboard</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			/* Reset and base styles reinforced */
			html,
			body {
				margin: 0;
				padding: 0;
				overflow: hidden;
				font-family: "Inter", sans-serif;
			}

			.dashboard-window {
				width: 440px;
				background-color: #171920;
				border-radius: 16px;
				padding: 32px;
				display: flex;
				flex-direction: column;
				gap: 32px;
				box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
				border: 1px solid rgba(255, 255, 255, 0.03);
				z-index: 100;
				position: relative;
				user-select: none;
			}

			.window-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.window-title {
				font-size: 1rem;
				font-weight: 700;
				color: #f0f0f8;
				margin: 0;
			}

			.minimize-btn {
				background: transparent;
				border: none;
				color: #aaaab2;
				cursor: pointer;
				opacity: 0.6;
				transition: opacity 0.2s;
				padding: 0;
			}

			.battery-section {
				display: flex;
				justify-content: center;
			}

			.battery-ring {
				position: relative;
				width: 200px;
				height: 200px;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.ring-core {
				display: flex;
				flex-direction: column;
				align-items: center;
				z-index: 10;
			}

			.battery-value {
				font-size: 3.5rem;
				font-weight: 800;
				color: #f0f0f8;
				line-height: 1;
			}

			.charging-status {
				display: flex;
				align-items: center;
				gap: 4px;
				margin-top: 12px;
				color: #5dfd8c;
				background: rgba(93, 253, 140, 0.1);
				padding: 4px 10px;
				border-radius: 20px;
			}

			.status-text {
				font-size: 0.65rem;
				font-weight: 800;
				letter-spacing: 0.05em;
			}

			.progress-svg {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				transform: rotate(-90deg);
			}

			.svg-track {
				fill: transparent;
				stroke: #23262e;
				stroke-width: 8;
			}

			.svg-progress {
				fill: transparent;
				stroke: #5dfd8c;
				stroke-width: 8;
				stroke-linecap: round;
				filter: drop-shadow(0 0 8px rgba(93, 253, 140, 0.4));
			}

			.settings-list {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}

			.setting-item {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			.setting-info {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.setting-label {
				font-size: 0.65rem;
				font-weight: 700;
				color: #aaaab2;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}

			.setting-value {
				font-size: 0.75rem;
				font-weight: 700;
				color: #5dfd8c;
			}

			.slider-container {
				cursor: pointer;
				padding: 8px 0;
			}

			.slider-track {
				height: 4px;
				background: #23262e;
				border-radius: 2px;
				position: relative;
			}

			.slider-fill {
				height: 100%;
				background: #5dfd8c;
				border-radius: 2px;
				pointer-events: none;
			}

			.slider-thumb {
				position: absolute;
				top: 50%;
				transform: translate(-50%, -50%);
				width: 12px;
				height: 12px;
				background: #5dfd8c;
				border-radius: 4px;
				box-shadow: 0 0 10px rgba(93, 253, 140, 0.5);
				pointer-events: none;
			}

			.setting-toggle-item {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 8px;
			}

			.toggle-switch {
				width: 44px;
				height: 22px;
				background: #23262e;
				border-radius: 11px;
				position: relative;
				cursor: pointer;
				transition: background 0.3s;
			}

			.toggle-switch.active {
				background: #5dfd8c;
			}

			.toggle-thumb {
				width: 18px;
				height: 18px;
				background: #000;
				border-radius: 50%;
				position: absolute;
				top: 2px;
				left: 2px;
				transition: transform 0.3s;
				pointer-events: none;
			}

			.toggle-switch.active .toggle-thumb {
				transform: translateX(22px);
			}

			.window-footer {
				margin-top: 8px;
				opacity: 0.5;
			}

			.window-footer p {
				font-size: 0.6rem;
				color: #aaaab2;
				text-align: center;
				line-height: 1.5;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<main class="dashboard-window">
			<header class="window-header">
				<h1 class="window-title">PowerAlert</h1>
				<button class="minimize-btn" aria-label="Réduire">
					<span class="material-symbols-outlined">remove</span>
				</button>
			</header>

			<section class="battery-section">
				<div class="battery-ring" id="battery-ring">
					<div class="ring-core">
						<span class="battery-value" id="battery-value">85%</span
						>
						<div class="charging-status">
							<span
								class="material-symbols-outlined"
								style="font-size: 14px; font-variation-settings: 'FILL' 1;"
								>bolt</span
							>
							<span class="status-text">EN CHARGE</span>
						</div>
					</div>
					<svg class="progress-svg" viewBox="0 0 200 200">
						<circle class="svg-track" cx="100" cy="100" r="90"
						></circle>
						<circle
							class="svg-progress"
							id="battery-progress"
							cx="100"
							cy="100"
							r="90"
							stroke-dasharray="565.48"
							stroke-dashoffset="84.82"></circle>
					</svg>
				</div>
			</section>

			<section class="settings-list">
				<!-- Max Charge Alerte -->
				<div class="setting-item">
					<div class="setting-info">
						<label class="setting-label"
							>ALERTE DE CHARGE MAXIMALE (%)</label
						>
						<span class="setting-value" id="max-charge-val"
							>100</span
						>
					</div>
					<div class="slider-container" id="max-charge-slider">
						<div class="slider-track">
							<div
								class="slider-fill"
								id="max-charge-fill"
								style="width: 100%;"
							>
							</div>
							<div
								class="slider-thumb"
								id="max-charge-thumb"
								style="left: 100%;"
							>
							</div>
						</div>
					</div>
				</div>

				<!-- Low Battery Alerte -->
				<div class="setting-item">
					<div class="setting-info">
						<label class="setting-label"
							>ALERTE DE BATTERIE FAIBLE (%)</label
						>
						<span class="setting-value" id="low-battery-val"
							>50</span
						>
					</div>
					<div class="slider-container" id="low-battery-slider">
						<div class="slider-track">
							<div
								class="slider-fill"
								id="low-battery-fill"
								style="width: 50%;"
							>
							</div>
							<div
								class="slider-thumb"
								id="low-battery-thumb"
								style="left: 50%;"
							>
							</div>
						</div>
					</div>
				</div>

				<!-- Desktop Sync Toggle -->
				<div class="setting-toggle-item">
					<label
						class="setting-label"
						style="max-width: 200px; text-transform:none;"
						>Lancer PowerAlert au démarrage de Windows</label
					>
					<div class="toggle-switch active" id="startup-toggle">
						<div class="toggle-thumb"></div>
					</div>
				</div>
			</section>

			<footer class="window-footer">
				<p>
					Paramètres sauvegardés automatiquement. La fermeture réduit
					l'application en arrière-plan.
				</p>
			</footer>
		</main>

		<script>
			import { invoke } from "@tauri-apps/api/core";
			import { listen } from "@tauri-apps/api/event";
			import { enable, disable } from "@tauri-apps/plugin-autostart";

			interface BatteryInfo {
				percentage: number;
				is_plugged_in: boolean;
				state: string;
			}

			interface AppConfig {
				low_threshold: number;
				high_threshold: number;
				run_at_startup: boolean;
			}

			// Mise à jour de l'affichage de la batterie
			function updateBatteryUI(info: BatteryInfo) {
				const valueLabel = document.getElementById("battery-value");
				const progress = document.getElementById("battery-progress");
				const statusText = document.querySelector(".status-text");
				const chargingIcon = document.querySelector(".charging-status .material-symbols-outlined");

				if (valueLabel) valueLabel.textContent = `${Math.round(info.percentage)}%`;
				
				if (progress) {
					const radius = 90;
					const circumference = 2 * Math.PI * radius;
					const offset = circumference - (info.percentage / 100) * circumference;
					progress.style.strokeDashoffset = offset.toString();
					
					// Changement de couleur selon le niveau
					const svgProgress = progress as unknown as SVGCircleElement;
					if (info.percentage <= 20) {
						svgProgress.style.stroke = "#ff4d4d";
					} else if (info.percentage <= 50) {
						svgProgress.style.stroke = "#ff9f43";
					} else {
						svgProgress.style.stroke = "#5dfd8c";
					}
				}

				if (statusText) statusText.textContent = info.is_plugged_in ? "EN CHARGE" : "SUR BATTERIE";
				if (chargingIcon) (chargingIcon as any).style.display = info.is_plugged_in ? "block" : "none";
			}

			// Retarde l'exécution d'une fonction jusqu'à la fin d'une période d'inactivité
			function debounce<T extends unknown[]>(fn: (...args: T) => void, delayMs: number) {
				let timer: ReturnType<typeof setTimeout>;
				return (...args: T) => {
					clearTimeout(timer);
					timer = setTimeout(() => fn(...args), delayMs);
				};
			}

			// Gestion des Sliders de pourcentage
			function initSlider(
				sliderId: string,
				valueId: string,
				fillId: string,
				thumbId: string,
				onChange?: (val: number) => void
			) {
				const slider = document.getElementById(sliderId);
				const valueLabel = document.getElementById(valueId);
				const fill = document.getElementById(fillId);
				const thumb = document.getElementById(thumbId);

				if (!slider || !valueLabel || !fill || !thumb) return;

				let isDragging = false;

				function setUIValue(percentage: number) {
					if (!valueLabel || !fill || !thumb) return;
					valueLabel.textContent = percentage.toString();
					fill.style.width = percentage + "%";
					thumb.style.left = percentage + "%";
				}

				function updateValue(clientX: number, finalize = false) {
					if (!slider) return;
					const rect = slider.getBoundingClientRect();
					let percentage = ((clientX - rect.left) / rect.width) * 100;
					percentage = Math.min(100, Math.max(0, Math.round(percentage)));

					setUIValue(percentage);
					if (finalize && onChange) {
						onChange(percentage);
					}
				}

				slider.addEventListener("mousedown", (e: MouseEvent) => {
					isDragging = true;
					updateValue(e.clientX);
				});

				window.addEventListener("mousemove", (e: MouseEvent) => {
					if (isDragging) {
						updateValue(e.clientX);
					}
				});

				window.addEventListener("mouseup", (e: MouseEvent) => {
					if (isDragging) {
						isDragging = false;
						updateValue(e.clientX, true);
					}
				});

				// Support tactile
				slider.addEventListener("touchstart", (e: TouchEvent) => {
					isDragging = true;
					if (e.touches[0]) updateValue(e.touches[0].clientX);
				});

				window.addEventListener("touchmove", (e: TouchEvent) => {
					if (isDragging && e.touches[0]) {
						updateValue(e.touches[0].clientX);
					}
				});

				window.addEventListener("touchend", (e: TouchEvent) => {
					if (isDragging) {
						isDragging = false;
						// Pour le tactile on ne récupère pas facilement la position finale du doigt
						// On se contente de la dernière valeur
						const finalVal = parseInt(valueLabel.textContent || "0");
						if (onChange) onChange(finalVal);
					}
				});

				return { setUIValue };
			}

			// Configuration locale
			let currentConfig: AppConfig = {
				low_threshold: 50,
				high_threshold: 100,
				run_at_startup: false
			};

			async function saveCurrentConfig() {
				try {
					console.log("Saving config...", currentConfig);
					await invoke("save_config", { config: currentConfig });
					
					// Activation réelle au niveau du système (plugin-autostart)
					if (currentConfig.run_at_startup) {
						await enable();
					} else {
						await disable();
					}
				} catch (err) {
					console.error("Failed to save config:", err);
				}
			}

			// Initialisation des sliders
			const debouncedSave = debounce(() => saveCurrentConfig(), 300);

			const maxSlider = initSlider(
				"max-charge-slider",
				"max-charge-val",
				"max-charge-fill",
				"max-charge-thumb",
				(val) => {
					currentConfig.high_threshold = val;
					debouncedSave();
				}
			);

			const lowSlider = initSlider(
				"low-battery-slider",
				"low-battery-val",
				"low-battery-fill",
				"low-battery-thumb",
				(val) => {
					currentConfig.low_threshold = val;
					debouncedSave();
				}
			);

			// Gestion du Toggle
			const startupToggle = document.getElementById("startup-toggle");
			if (startupToggle) {
				startupToggle.addEventListener("click", () => {
					startupToggle.classList.toggle("active");
					currentConfig.run_at_startup = startupToggle.classList.contains("active");
					saveCurrentConfig();
				});
			}

			// Chargement initial et écoute des événements
			async function init() {
				try {
					// 1. Charger la config
					const config = await invoke("get_config") as AppConfig;
					currentConfig = config;
					
					if (maxSlider) maxSlider.setUIValue(config.high_threshold);
					if (lowSlider) lowSlider.setUIValue(config.low_threshold);
					if (startupToggle) {
						if (config.run_at_startup) startupToggle.classList.add("active");
						else startupToggle.classList.remove("active");
					}

					// 2. Charger l'état actuel de la batterie
					const initialStatus = await invoke("get_battery_status") as BatteryInfo;
					updateBatteryUI(initialStatus);

					// 3. Écouter les mises à jour
					await listen("battery-status", (event) => {
						updateBatteryUI(event.payload as BatteryInfo);
					});

					console.log("PowerAlert IPC Initialized");
				} catch (err) {
					console.error("IPC Error:", err);
				}
			}

			// Démarrage
			init();

			// Effet visuel bonus
			const batteryRing = document.getElementById("battery-ring");
			if (batteryRing) {
				batteryRing.style.transition = "transform 0.3s ease";
				batteryRing.addEventListener("mouseenter", () => {
					batteryRing.style.transform = "scale(1.02)";
				});
				batteryRing.addEventListener("mouseleave", () => {
					batteryRing.style.transform = "scale(1)";
				});
			}
		</script>
	</body>
</html>
