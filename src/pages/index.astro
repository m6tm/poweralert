---
import '../styles/global.css';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>PowerAlert - Kinetic Dashboard</title>
		<!-- Google Fonts - Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
	</head>
	<body class="glass">
		<main id="dashboard" class="dashboard-container">
			<!-- Header / Top Bar -->
			<header class="header-bar">
				<div class="logo">
					<span class="logo-dot"></span>
					<h1 class="headline-sm">POWERALERT</h1>
				</div>
				<div class="status-chip active">
					EN CHARGE
				</div>
			</header>

			<!-- Central Battery Pulse -->
			<section class="battery-pulse-section">
				<div class="pulse-ring">
					<div class="pulse-core">
						<span class="display-lg">84<span class="percent">%</span></span>
					</div>
					<!-- Custom progress SVG circular track -->
					<svg class="progress-ring" viewBox="0 0 200 200">
						<circle class="ring-track" cx="100" cy="100" r="90" fill="transparent" stroke-width="2"></circle>
						<circle class="ring-progress" cx="100" cy="100" r="90" fill="transparent" stroke-width="4" stroke-dasharray="565.48" stroke-dashoffset="90.47"></circle>
					</svg>
				</div>
			</section>

			<!-- Technical Data Grid (Increased Spacing) -->
			<section class="data-grid">
				<div class="data-module">
					<label class="data-label">VOLTAGE</label>
					<span class="data-value">12.8<span class="unit">V</span></span>
				</div>
				<div class="data-module">
					<label class="data-label">AMPERAGE</label>
					<span class="data-value">4.2<span class="unit">A</span></span>
				</div>
				<div class="data-module">
					<label class="data-label">TEMPERATURE</label>
					<span class="data-value">34<span class="unit">°C</span></span>
				</div>
				<div class="data-module">
					<label class="data-label">EFFICIENCY</label>
					<span class="data-value">98<span class="unit">%</span></span>
				</div>
			</section>

			<!-- Throttling Slider Module -->
			<section class="controls-section">
				<div class="control-card">
					<div class="control-header">
						<label class="data-label">POWER THROTTLING</label>
						<span class="data-value">60%</span>
					</div>
					<div class="custom-slider">
						<div class="slider-track">
							<div class="slider-fill" style="width: 60%;"></div>
							<div class="slider-thumb" style="left: 60%;"></div>
						</div>
					</div>
				</div>
			</section>
		</main>

		<style>
			.dashboard-container {
				width: 100%;
				max-width: 960px;
				margin: 0 auto;
				padding: var(--spacing-12) var(--spacing-8); /* Padding généreux (Increased Spacing) */
				height: 100vh;
				display: flex;
				flex-direction: column;
				gap: var(--spacing-12); /* Espacement augmenté entre sections */
			}

			.header-bar {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.logo {
				display: flex;
				align-items: center;
				gap: var(--spacing-3);
			}

			.logo-dot {
				width: 8px;
				height: 8px;
				background-color: var(--color-primary);
				border-radius: 50%;
				box-shadow: 0 0 8px var(--color-primary);
			}

			.headline-sm {
				font-size: 1.5rem;
				letter-spacing: 0.1em;
				font-weight: 700;
			}

			.status-chip {
				padding: var(--spacing-2) var(--spacing-4);
				background: rgba(93, 253, 140, 0.1);
				color: var(--color-primary);
				border-radius: var(--radius-md);
				font-size: 0.6875rem;
				font-weight: 600;
				letter-spacing: 0.05em;
			}

			/* Central Battery Indicator */
			.battery-pulse-section {
				flex: 1;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.pulse-ring {
				position: relative;
				width: 320px;
				height: 320px;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.pulse-core {
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.display-lg {
				font-size: 6rem;
				font-weight: 800;
				line-height: 1;
                background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
			}

			.percent {
				font-size: 2.5rem;
				font-weight: 400;
				color: var(--color-on-surface-variant);
			}

			.progress-ring {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				transform: rotate(-90deg);
			}

			.ring-track {
				stroke: var(--color-surface-container-high);
			}

			.ring-progress {
				stroke: var(--color-primary);
				stroke-linecap: round;
				filter: drop-shadow(0 0 10px rgba(93, 253, 140, 0.4));
			}

			/* Technical Data Grid */
			.data-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: var(--spacing-8); /* Spacing augmenté */
			}

			.data-module {
				display: flex;
				flex-direction: column;
				gap: var(--spacing-2);
				padding: var(--spacing-4);
                background: var(--color-surface-container-low);
                border-radius: var(--radius-md);
                border: 1px solid rgba(255, 255, 255, 0.03); /* Whisper of a line pour accessibilité */
			}

			.data-label {
				font-size: 0.6875rem;
				color: var(--color-on-surface-variant);
				letter-spacing: 0.1em;
				font-weight: 500;
			}

			.data-value {
				font-size: 1.5rem;
				font-weight: 600;
				font-variant-numeric: tabular-nums;
			}

			.unit {
				font-size: 0.875rem;
				color: var(--color-on-surface-variant);
				margin-left: 2px;
			}

			/* Throttling Slider */
			.control-card {
				background: var(--color-surface-container);
				padding: var(--spacing-6);
				border-radius: var(--radius-lg);
				display: flex;
				flex-direction: column;
				gap: var(--spacing-6);
			}

			.control-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
			}

			.custom-slider {
				padding: var(--spacing-4) 0;
			}

			.slider-track {
				height: var(--spacing-2);
				background: var(--color-surface-container-highest);
				border-radius: 4px;
				position: relative;
			}

			.slider-fill {
				height: 100%;
				background: linear-gradient(90deg, var(--color-primary-container), var(--color-primary));
				border-radius: 4px;
				box-shadow: 0 0 12px rgba(93, 253, 140, 0.3);
			}

			.slider-thumb {
				position: absolute;
				top: 50%;
				transform: translate(-50%, -50%);
				width: 20px;
				height: 20px;
				background: var(--color-primary);
				border-radius: 4px; /* Architectural square thumb as per design system */
				cursor: pointer;
			}
		</style>
	</body>
</html>
